# # ═══════════════════════════════════════════════════════════════════════════
# # RAG Platform — Environment Configuration
# # Copy this file to .env and fill in your values.
# # ═══════════════════════════════════════════════════════════════════════════

# # ── Application ──────────────────────────────────────────────────────────
# APP_NAME="RAG Platform"
# DEBUG=false
# SECRET_KEY=change-me-to-a-random-string

# # ── Authentication ───────────────────────────────────────────────────────
# JWT_SECRET=change-me-to-a-random-jwt-secret

# # ── Database ─────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ragplatform

# # ── Redis ────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis:6379/0

# # ── Pluggable Providers ──────────────────────────────────────────────────
# # Options: pinecone | qdrant | faiss | weaviate | milvus
# VECTOR_DB_PROVIDER=pinecone

# # Options: nvidia | openai | bge | sentence-transformers
# EMBEDDING_PROVIDER=nvidia

# # Options: nvidia | openai | ollama | anthropic | gemini | deepseek
# LLM_PROVIDER=nvidia

# # ── NVIDIA NIM APIs ──────────────────────────────────────────────────────
# NV_API_KEY=
# NV_CHAT_API_KEY=
# NV_API_BASE_URL=https://integrate.api.nvidia.com/v1
# NV_EMBED_MODEL=nvidia/nv-embed-v1
# NV_CHAT_MODEL=meta/llama-3.1-70b-instruct

# # ── OpenAI (optional) ───────────────────────────────────────────────────
# OPENAI_API_KEY=

# # ── Pinecone ─────────────────────────────────────────────────────────────
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=rag-platform
# PINECONE_HOST=

# # ── Qdrant (optional) ───────────────────────────────────────────────────
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333

# # ── Telegram Bot (optional) ─────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# # ── Chunking ─────────────────────────────────────────────────────────────
# CHUNK_TOKEN_SIZE=300
# CHUNK_TOKEN_OVERLAP=30
# MAX_CHUNK_TOKEN_SIZE=450

# # ── Retrieval ────────────────────────────────────────────────────────────
# RELEVANCE_THRESHOLD=0.40
# TOP_K=5

# # ── Rate Limiting ────────────────────────────────────────────────────────
# RATE_LIMIT_PER_MINUTE=60

# # ── Monitoring ───────────────────────────────────────────────────────────
# PROMETHEUS_ENABLED=true
